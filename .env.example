# Payment Links (alternative to checkout sessions - recommended for simplicity)
# Get these from Stripe Dashboard > Products > Your Product > Payment Links
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/test_4gM7sL2yogQ93il4Ox97G00?client_reference_id={USER_ID}
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_QUARTERLY=https://buy.stripe.com/test_xxxxxxxxxxxxx?client_reference_id={USER_ID}
