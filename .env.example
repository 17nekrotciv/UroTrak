# ==============================================================================
# = Firebase Configuration - UroTrack
# ==============================================================================
#
# INSTRUCTIONS:
# 1. DO NOT edit this file directly.
# 2. CREATE A NEW FILE named '.env.local' in the root of the project.
# 3. Go to your Firebase Project Settings > General tab.
# 4. Scroll down to "Your apps" and click the '</>' icon for your web app.
# 5. You will see a 'firebaseConfig' object. Copy each value into the
#    corresponding variable below in your '.env.local' file.
# 6. VERY IMPORTANT: After saving '.env.local', you MUST restart your
#    development server (Ctrl+C and then 'npm run dev').
#
# ------------------------------------------------------------------------------

# Found in your Firebase project's web app configuration
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD_8FjNH0GDO7_Kc4Xsc4fgQ6CyUVoSTJU
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=urotrack-qqp6e.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=urotrack-qqp6e
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=urotrack-qqp6e.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=386452337737
NEXT_PUBLIC_FIREBASE_APP_ID=1:386452337737:web:fed1756ec30993640bfb98

# ==============================================================================
# = Stripe Configuration
# ==============================================================================
#
# Get these values from https://dashboard.stripe.com/test/apikeys
# See docs/STRIPE_SETUP.md for detailed instructions
#
# Price IDs for subscription plans (from Stripe Products)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxx
